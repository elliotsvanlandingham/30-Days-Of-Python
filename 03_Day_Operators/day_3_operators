# The equation: 0 = x² + 6x + 9
b = 6 # Middle number
c = 9 # Last number

print(f"Solving for x when: x² + {b}x + {c} = 0")

# The fastest shortcut to solve this equation
# 1. Cut the middle number in half
half_b = b // 2

# 2. Check if it's a perfecrt square
if half_b * half_b  == c:
    # 3. Flip the sign to get the solution
    x = -half_b
    print(f"Success! The value of x is: {x}")
else:
    print("This specific shortcut only works for perfect squares.")

